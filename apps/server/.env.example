# Server Environment Variables

# The URL to the PostgreSQL database running via Docker Compose
DATABASE_URL="postgresql://admin:password123@localhost:5432/asgard_db?schema=public"

# The port the Express HTTP server should run on
PORT=3000

# Stellar Network Configuration (TESTNET or PUBLIC)
STELLAR_NETWORK="TESTNET"

# Optional: Add any Soroban RPC URLs or Secret Keys below if needed for backend processes
# SOROBAN_RPC_URL="https://soroban-testnet.stellar.org:443"
# SERVER_SECRET_KEY="S..."
